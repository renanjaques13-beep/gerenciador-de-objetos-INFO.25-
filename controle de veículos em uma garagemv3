public class Carro {
    private String marca;
    private String modelo;
    private String placa;
    private Motor motor;
    private Condutor condutor;
    
   
    public Carro(String marca, String modelo, String placa) {
        this.marca = marca;
        this.modelo = modelo;
        this.placa = placa;
        this.motor = new Motor(); // Motor padrão
        this.condutor = null; // Sem condutor inicialmente
    }
    

    public Carro(String marca, String modelo, String placa, Motor motor) {
        this.marca = marca;
        this.modelo = modelo;
        this.placa = placa;
        this.motor = motor;
        this.condutor = null;
    }
    
    // Construtor 3: Com motor e condutor
    public Carro(String marca, String modelo, String placa, Motor motor, Condutor condutor) {
        this.marca = marca;
        this.modelo = modelo;
        this.placa = placa;
        this.motor = motor;
        this.condutor = condutor;
    }
    

    public void atualizarCondutor(Condutor novoCondutor) {
        this.condutor = novoCondutor;
        System.out.println("Condutor atualizado com sucesso!");
    }
    
 
    public void atualizarMotor(Motor novoMotor) {
        this.motor = novoMotor;
        System.out.println("Motor atualizado com sucesso!");
    }
    

    public void atualizarDados(String marca, String modelo, String placa) {
        this.marca = marca;
        this.modelo = modelo;
        this.placa = placa;
        System.out.println("Dados do carro atualizados!");
    }
    
 
    public void atualizarDados(String marca, String modelo, String placa, Motor motor) {
        this.marca = marca;
        this.modelo = modelo;
        this.placa = placa;
        this.motor = motor;
        System.out.println("Dados do carro e motor atualizados!");
    }
    

    public String getMarca() {
        return marca;
    }
    
    public void setMarca(String marca) {
        this.marca = marca;
    }
    
    public String getModelo() {
        return modelo;
    }
    
    public void setModelo(String modelo) {
        this.modelo = modelo;
    }
    
    public String getPlaca() {
        return placa;
    }
    
    public void setPlaca(String placa) {
        this.placa = placa;
    }
    
    public Motor getMotor() {
        return motor;
    }
    
    public void setMotor(Motor motor) {
        this.motor = motor;
    }
    
    public Condutor getCondutor() {
        return condutor;
    }
    
    public void setCondutor(Condutor condutor) {
        this.condutor = condutor;
    }
    
  
    public void exibirInformacoes() {
        System.out.println("\n=== INFORMAÇÕES DO CARRO ===");
        System.out.println("Marca: " + marca);
        System.out.println("Modelo: " + modelo);
        System.out.println("Placa: " + placa);
        System.out.println("Motor: " + motor);
        System.out.println("Condutor: " + (condutor != null ? condutor : "Nenhum condutor associado"));
        System.out.println("============================\n");
    }
}
